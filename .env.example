OPENAI_API_KEY=your_api_key_here

# Optional overrides (defaults shown)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_SIMULATE=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_PRD=gpt-4o

# Reddit API (optional) — enables reliable "real user voices" from Reddit.
# Without these, Reddit is skipped (its public search endpoint blocks bots).
# Create an app at https://www.reddit.com/prefs/apps (type: "script" or "web app").
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=UserResearchOS/1.0 (by /u/yourusername)
